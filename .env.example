APP_NAME=EduMatch Resource Mapping API

MONGODB_URL=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=edumatch_resource_db

JWT_SECRET_KEY=your-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

FRONTEND_URL=http://localhost:5173

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

OPENAI_API_KEY=your-openai-api-key-if-needed
USE_OPENAI_EXTRACTION=false
OPENAI_EXTRACTION_MODEL=gpt-5.4-mini
OPENAI_EXTRACTION_MAX_INPUT_CHARS=3500
OPENAI_EXTRACTION_MAX_OUTPUT_TOKENS=800
OPENAI_EXTRACTION_MIN_MISSING_FIELDS=2
OPENAI_EXTRACTION_TIMEOUT_SECONDS=12
USE_EMBEDDING_MATCHING=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=256
OPENAI_EMBEDDING_TIMEOUT_SECONDS=8
OPENAI_EMBEDDING_MAX_INPUT_CHARS=900
OPENAI_EMBEDDING_SKIP_IF_LOCAL_AT_LEAST=0.72
OPENAI_EMBEDDING_SKIP_IF_LOCAL_BELOW=0.12
OPENAI_EMBEDDING_EXPAND_LOW_CONFIDENCE=false
